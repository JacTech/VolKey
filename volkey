#!/usr/bin/env python3
"""
volkey - Per-application volume control with global hotkeys.
Fedora / PipeWire (pactl compatible).
"""

import argparse
import json
import os
import re
import subprocess
import sys
from pathlib import Path

VERSION = "1.4.0"

CONFIG_PATH = Path(os.environ.get("VOLKEY_CONFIG", Path.home() / ".config" / "volkey" / "config.json"))
SERVICE_PATH = Path.home() / ".config" / "systemd" / "user" / "volkey.service"
INSTALL_PATH = Path("/usr/local/bin/volkey")

DEFAULT_CONFIG = {
    "notify": False,
    "step": 5,
    "bindings": [
        {"keys": ["ctrl",  "volume_up"],          "app": "firefox",  "delta":  5},
        {"keys": ["ctrl",  "volume_down"],         "app": "firefox",  "delta": -5},
        {"keys": ["shift", "volume_up"],           "app": "discord",  "delta":  5},
        {"keys": ["shift", "volume_down"],         "app": "discord",  "delta": -5},
        {"keys": ["ctrl", "shift", "volume_up"],   "app": "spotify",  "delta":  5},
        {"keys": ["ctrl", "shift", "volume_down"], "app": "spotify",  "delta": -5},
    ],
}

VALID_MODIFIERS = ["ctrl", "shift", "alt"]
VALID_ACTION_KEYS = ["volume_up", "volume_down", "volume_mute"]
ALL_VALID_KEYS = VALID_MODIFIERS + VALID_ACTION_KEYS

# ── Config ─────────────────────────────────────────────────────────────────────

def load_config() -> dict:
    if not CONFIG_PATH.exists():
        CONFIG_PATH.parent.mkdir(parents=True, exist_ok=True)
        with open(CONFIG_PATH, "w") as f:
            json.dump(DEFAULT_CONFIG, f, indent=2)
        print(f"[volkey] Created default config at {CONFIG_PATH}")
        print(f"[volkey] Edit it to set your apps and hotkeys.\n")
    with open(CONFIG_PATH) as f:
        return json.load(f)

def save_config(config: dict):
    with open(CONFIG_PATH, "w") as f:
        json.dump(config, f, indent=2)


# ── PulseAudio / PipeWire helpers ──────────────────────────────────────────────

def get_sink_inputs() -> list[dict]:
    try:
        out = subprocess.check_output(["pactl", "list", "sink-inputs"], text=True)
    except FileNotFoundError:
        print("[volkey] `pactl` not found. Install pipewire-pulseaudio.")
        sys.exit(1)

    streams = []
    current: dict = {}
    for line in out.splitlines():
        line = line.strip()
        m = re.match(r"^Sink Input #(\d+)$", line)
        if m:
            if current:
                streams.append(current)
            current = {"index": m.group(1), "app_name": "", "volume_pct": 0, "muted": False}
            continue
        m = re.match(r"application\.name\s*=\s*\"(.+?)\"", line)
        if m and current:
            current["app_name"] = m.group(1)
            continue
        m = re.match(r"Mute:\s*(yes|no)", line)
        if m and current:
            current["muted"] = m.group(1) == "yes"
            continue
        m = re.match(r"Volume:.+?(\d+)%", line)
        if m and current:
            current["volume_pct"] = int(m.group(1))
    if current:
        streams.append(current)
    return streams

def find_streams_for_app(app_pattern: str) -> list[dict]:
    return [s for s in get_sink_inputs() if app_pattern.lower() in s["app_name"].lower()]

def set_volume(sink_index: str, volume_pct: int):
    volume_pct = max(0, min(150, volume_pct))
    subprocess.run(["pactl", "set-sink-input-volume", sink_index, f"{volume_pct}%"], check=True)

def change_volume(app_pattern: str, delta: int, notify: bool = False):
    streams = find_streams_for_app(app_pattern)
    if not streams:
        msg = f"[volkey] No active audio stream matching '{app_pattern}'"
        print(msg)
        if notify:
            _notify("volkey", msg, urgency="low")
        return
    for s in streams:
        new_vol = max(0, min(150, s["volume_pct"] + delta))
        set_volume(s["index"], new_vol)
        print(f"[volkey] {s['app_name']} -> {new_vol}%")
        if notify:
            _notify(f"🔊 {s['app_name']}", f"Volume: {new_vol}%")

def _notify(summary: str, body: str, urgency: str = "normal"):
    try:
        subprocess.run(
            ["notify-send", "-u", urgency, "-t", "1500", summary, body],
            check=False, capture_output=True
        )
    except FileNotFoundError:
        pass

# ── Hotkey listener (evdev — works on Wayland) ────────────────────────────────

def _build_key_map():
    try:
        from evdev import ecodes
    except ImportError:
        return None
    return {
        "ctrl":         {ecodes.KEY_LEFTCTRL,  ecodes.KEY_RIGHTCTRL},
        "shift":        {ecodes.KEY_LEFTSHIFT, ecodes.KEY_RIGHTSHIFT},
        "alt":          {ecodes.KEY_LEFTALT,   ecodes.KEY_RIGHTALT},
        "volume_up":    {ecodes.KEY_VOLUMEUP},
        "volume_down":  {ecodes.KEY_VOLUMEDOWN},
        "volume_mute":  {ecodes.KEY_MUTE},
    }

def _find_input_devices():
    """Return all readable keyboard-like input devices."""
    from evdev import InputDevice, ecodes, list_devices
    devices = []
    for path in list_devices():
        try:
            dev = InputDevice(path)
            caps = dev.capabilities()
            keys = caps.get(ecodes.EV_KEY, [])
            interesting = {
                ecodes.KEY_LEFTCTRL, ecodes.KEY_RIGHTCTRL,
                ecodes.KEY_LEFTSHIFT, ecodes.KEY_RIGHTSHIFT,
                ecodes.KEY_VOLUMEUP, ecodes.KEY_VOLUMEDOWN, ecodes.KEY_MUTE,
            }
            if interesting & set(keys):
                devices.append(dev)
        except (PermissionError, OSError):
            pass
    return devices

def start_listener(config: dict):
    try:
        import evdev
        from evdev import ecodes, KeyEvent
        import asyncio
        import threading
    except ImportError:
        print("[volkey] evdev not installed. Run: pip install evdev")
        sys.exit(1)

    key_map = _build_key_map()
    notify  = config.get("notify", False)

    hotkeys = []
    for b in config.get("bindings", []):
        keys_str   = [k.lower() for k in b["keys"]]
        modifiers  = set()
        action_set = set()
        ok = True
        for k in keys_str:
            if k not in key_map:
                print(f"[volkey] Unknown key '{k}' in binding {b}, skipping.")
                ok = False
                break
            codes = key_map[k]
            if k in VALID_MODIFIERS:
                modifiers |= codes
            else:
                action_set |= codes
        if ok and action_set:
            hotkeys.append((modifiers, action_set, b["app"], b["delta"]))

    devices = _find_input_devices()
    if not devices:
        print("[volkey] No readable input devices found.")
        print("  Make sure you are in the 'input' group:")
        print("    sudo usermod -aG input $USER   (then log out and back in)")
        sys.exit(1)

    all_modifier_codes = set()
    for mods, _, _, _ in hotkeys:
        all_modifier_codes |= mods

    held = set()

    async def handle_device(dev):
        from evdev import KeyEvent
        try:
            async for event in dev.async_read_loop():
                if event.type != ecodes.EV_KEY:
                    continue
                code  = event.code
                state = event.value  # 1=down, 0=up, 2=hold

                if state == 1:  # key down
                    held.add(code)
                    for mod_codes, action_codes, app, delta in hotkeys:
                        if code in action_codes:
                            all_mods_held = True
                            for name in VALID_MODIFIERS:
                                group = key_map[name]
                                if group & mod_codes:      # modifier is required
                                    if not (group & held): # but none of its keys are held
                                        all_mods_held = False
                                        break
                                else:                      # modifier is NOT required
                                    if group & held:       # but one of its keys is held
                                        all_mods_held = False
                                        break
                            if all_mods_held:
                                change_volume(app, delta, notify=notify)
                elif state == 0:  # key up
                    held.discard(code)
        except (OSError, KeyboardInterrupt):
            pass

    print(f"[VolKey] v{VERSION} — listening for hotkeys (evdev). Ctrl+C to quit.\n")
    for mod_codes, action_codes, app, delta in hotkeys:
        mod_names  = [n for n in VALID_MODIFIERS if key_map[n] & mod_codes]
        act_names  = [n for n in VALID_ACTION_KEYS if key_map[n] & action_codes]
        combo      = "+".join(mod_names + act_names)
        sign       = "+" if delta > 0 else ""
        print(f"  {combo:40s}  ->  {app}  {sign}{delta}%")
    print(f"\n  Listening on: {', '.join(d.path for d in devices)}\n")

    loop = asyncio.new_event_loop()
    tasks = [loop.create_task(handle_device(d)) for d in devices]
    try:
        loop.run_forever()
    except KeyboardInterrupt:
        for t in tasks:
            t.cancel()
        print("\n[VolKey] Stopped.")

